# Skyward authoritative world server (server/world.mjs) — production config.
# Copy to .env (gitignored) or set these in Cloud Run. All are OPTIONAL: with none
# set, the server runs on :8788 with a local file store and no LLM proxy.

# Port the WebSocket + HTTP world server listens on.
SKY_WORLD_PORT=8788

# Durable store. Omit → file store (server/data/*.json, fine for local/dev). Set to a
# Postgres URL for production persistence (Cloud SQL). The server lazily imports `pg`
# and creates a single JSONB key-value table; it falls back to files if unreachable.
# Cloud SQL (Unix socket) example:
# DATABASE_URL=postgres://USER:PASSWORD@/skyward?host=/cloudsql/PROJECT:REGION:INSTANCE

# LLM cognition proxy (/api/brain, /api/embed) for FIRST-PARTY in-browser agents + the
# "T" natural-language command. In a cloud deploy there is usually no model reachable
# (per the locked decision, agents bring their own brain), so /api/brain degrades
# gracefully to deterministic fallback. Set these only if the server can reach a model.
# OLLAMA_URL=http://localhost:11434
# SKY_MODEL=llama3.1:8b

# --- Security hardening (all OPTIONAL; safe local defaults) -------------------------
# CORS allowlist for the public client origin(s), comma-separated. UNSET → "*" (dev only).
# In production set this to your deployed client origin so other sites can't drive the API.
# SKY_ALLOWED_ORIGINS=https://play.skyward.example,https://skyward.example

# Proof-of-personhood. UNSET → a single-use arithmetic challenge (dev/default; weak on its
# own, backed by the per-IP registration cap). For a public beta, set a real captcha:
# SKY_POP_PROVIDER=turnstile          # turnstile | hcaptcha | recaptcha
# SKY_POP_SECRET=your-captcha-secret  # the provider's server-side secret key

# Session token lifetime in ms (default 30 days). Tokens rotate on every login.
# SKY_TOKEN_TTL_MS=2592000000

# Sign in with Google. Set to your OAuth 2.0 Web client ID (created in the Google Cloud
# Console → APIs & Services → Credentials). UNSET → the Google button stays hidden and
# /auth/google is disabled. Only the client ID is needed (no client secret for the GIS
# ID-token flow). Add your deployed origin to the client's Authorized JavaScript origins.
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# --- Gameplay AI brain — GAMEPLAY ONLY, no code/GitHub --------------------------
# PRODUCTION: run the brain CO-LOCATED inside the world service. Set SKY_BRAIN_INPROCESS=1
# on the world (Cloud Run) and put the provider key(s) below on the SAME service. No HTTP, no
# SKY_BRAIN_TOKEN needed in this mode (the brain calls the world in-memory).
# SKY_BRAIN_INPROCESS=1
#
# SKY_BRAIN_TOKEN only matters for the STANDALONE runner (server/brain.mjs, local/dev against a
# remote world) and to gate the external /brain/* endpoints + the owner Brain Console.
# SKY_BRAIN_TOKEN=choose-a-long-random-secret
# SKY_OWNER=yourhandle           # the account handle that may open the owner Brain Console
# SKY_PUBLIC_REPO=steffenpharai/skyward   # where builders file issues/PRs (orientation only)

# Brain model seam (provider-agnostic). Default 'deterministic' = $0, no key, works offline.
# Best-of-breed: Grok 4 Fast heartbeat -> Claude Opus 4.8 escalation.
# SKY_BRAIN_PROVIDER=deterministic     # deterministic | grok | openai | anthropic | ollama
# SKY_BRAIN_HEARTBEAT_MODEL=grok-4-fast
# SKY_BRAIN_DEEP_MODEL=claude-opus-4-8
# XAI_API_KEY=...                # for provider=grok
# OPENAI_API_KEY=...             # for provider=openai
# ANTHROPIC_API_KEY=...          # for provider=anthropic
# SKY_BRAIN_DAILY_TOKENS=2000000 # hard daily token ceiling (falls back to deterministic when hit)
# SKY_BRAIN_HEARTBEAT_MS=90000   # floor between LLM ticks; triggers can fire sooner
